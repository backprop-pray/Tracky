<mujoco model="farm_field">
    <option gravity="0 0 -9.81" timestep="0.001" integrator="implicitfast"/>

    <default>
        <geom condim="3" friction="1 0.005 0.0001" solref="0.01 1" solimp=".9 .95 .001"/>
        <joint damping="0.1"/>
    </default>

    <!-- ======================== ASSETS ======================== -->
    <asset>
        <!-- Ground textures -->
        <texture name="grass_tex" type="2d" builtin="checker"
                 rgb1="0.22 0.50 0.15" rgb2="0.28 0.55 0.20"
                 width="512" height="512"/>
        <material name="grass_mat" texture="grass_tex"
                  texrepeat="12 12" texuniform="true"
                  reflectance="0.05"/>

        <texture name="dirt_tex" type="2d" builtin="flat"
                 rgb1="0.55 0.38 0.22" rgb2="0.50 0.35 0.20"
                 width="64" height="64"/>
        <material name="dirt_mat" texture="dirt_tex" reflectance="0.02"/>

        <!-- Foliage colours -->
        <material name="trunk_mat"  rgba="0.45 0.28 0.12 1" reflectance="0.05"/>
        <material name="canopy_mat" rgba="0.18 0.55 0.18 1" reflectance="0.1"/>
        <material name="canopy_light_mat" rgba="0.30 0.65 0.22 1" reflectance="0.1"/>
        <material name="canopy_dark_mat"  rgba="0.12 0.42 0.14 1" reflectance="0.1"/>

        <!-- Crop colours -->
        <material name="crop_mat"   rgba="0.35 0.62 0.18 1" reflectance="0.05"/>
        <material name="crop_ripe_mat" rgba="0.80 0.72 0.15 1" reflectance="0.05"/>

        <!-- Bush / flower colours -->
        <material name="bush_mat"   rgba="0.20 0.50 0.15 1" reflectance="0.08"/>
        <material name="flower_red_mat"    rgba="0.85 0.15 0.15 1" reflectance="0.1"/>
        <material name="flower_yellow_mat" rgba="0.95 0.85 0.15 1" reflectance="0.1"/>
        <material name="flower_purple_mat" rgba="0.60 0.20 0.75 1" reflectance="0.1"/>
        <material name="flower_white_mat"  rgba="0.95 0.92 0.90 1" reflectance="0.1"/>

        <!-- Fence -->
        <material name="fence_mat" rgba="0.60 0.42 0.22 1" reflectance="0.05"/>

        <!-- Tractor colours -->
        <material name="chassis_mat" rgba="0.80 0.80 0.82 1" reflectance="0.3"/>
        <material name="wheel_mat"   rgba="0.12 0.12 0.12 1" reflectance="0.05"/>
        <material name="track_mat"   rgba="0.06 0.06 0.06 1" reflectance="0.02"/>
        <material name="motor_mat"   rgba="0.25 0.25 0.28 1" reflectance="0.15"/>

        <!-- Sky -->
        <texture name="sky_tex" type="skybox" builtin="gradient"
                 rgb1="0.40 0.65 0.95" rgb2="0.85 0.92 1.0"
                 width="512" height="512"/>
    </asset>

    <!-- ======================== WORLDBODY ======================== -->
    <worldbody>
        <!-- Warm sun-like directional light -->
        <light name="sun" directional="true" diffuse="1.0 0.95 0.8" specular="0.3 0.3 0.3"
               pos="5 -3 8" dir="-0.3 0.2 -1" castshadow="true"/>
        <light name="fill" directional="true" diffuse="0.3 0.35 0.45" specular="0.05 0.05 0.05"
               pos="-4 4 6" dir="0.3 -0.3 -1" castshadow="false"/>

        <!-- ===== GROUND ===== -->
        <geom name="grass_floor" type="plane" size="6 6 0.1" material="grass_mat"/>

        <!-- Dirt paths between crop rows -->
        <!-- Dirt paths removed for a clean grass field -->

        <!-- ===== TARGET (end of field) ===== -->
        <body name="target" pos="3.5 0 0.01">
            <geom name="target_geom" type="box" size=".3 .3 .01" rgba="1 0.3 0 0.5"
                  contype="0" conaffinity="0"/>
            <site name="target_site" pos="0 0 0" size="0.1"/>
        </body>

        <!-- ========================================================== -->
        <!--                         TREES                              -->
        <!-- ========================================================== -->

        <!-- Tree 1 — tall oak, back-left -->
        <body name="tree1" pos="-4.0 3.5 0">
            <geom name="trunk1" type="cylinder" size="0.12 0.55" pos="0 0 0.55"
                  material="trunk_mat" contype="1" conaffinity="1"/>
            <geom name="canopy1" type="sphere" size="0.65" pos="0 0 1.4"
                  material="canopy_mat" contype="0" conaffinity="0"/>
            <geom name="canopy1b" type="sphere" size="0.45" pos="0.25 0.2 1.7"
                  material="canopy_light_mat" contype="0" conaffinity="0"/>
        </body>

        <!-- Tree 2 — smaller tree, front-right -->
        <body name="tree2" pos="4.2 -3.0 0">
            <geom name="trunk2" type="cylinder" size="0.08 0.40" pos="0 0 0.40"
                  material="trunk_mat" contype="1" conaffinity="1"/>
            <geom name="canopy2" type="ellipsoid" size="0.50 0.50 0.40" pos="0 0 1.05"
                  material="canopy_dark_mat" contype="0" conaffinity="0"/>
        </body>

        <!-- Tree 3 — big tree, back-right corner -->
        <body name="tree3" pos="4.5 3.8 0">
            <geom name="trunk3" type="cylinder" size="0.15 0.65" pos="0 0 0.65"
                  material="trunk_mat" contype="1" conaffinity="1"/>
            <geom name="canopy3" type="sphere" size="0.80" pos="0 0 1.60"
                  material="canopy_mat" contype="0" conaffinity="0"/>
            <geom name="canopy3b" type="sphere" size="0.50" pos="-0.3 0.25 1.85"
                  material="canopy_light_mat" contype="0" conaffinity="0"/>
        </body>

        <!-- Tree 4 — medium tree, front-left -->
        <body name="tree4" pos="-3.5 -3.8 0">
            <geom name="trunk4" type="cylinder" size="0.10 0.50" pos="0 0 0.50"
                  material="trunk_mat" contype="1" conaffinity="1"/>
            <geom name="canopy4" type="ellipsoid" size="0.55 0.55 0.50" pos="0 0 1.25"
                  material="canopy_mat" contype="0" conaffinity="0"/>
        </body>

        <!-- Tree 5 — near center-right edge -->
        <body name="tree5" pos="4.8 0.5 0">
            <geom name="trunk5" type="cylinder" size="0.09 0.45" pos="0 0 0.45"
                  material="trunk_mat" contype="1" conaffinity="1"/>
            <geom name="canopy5" type="sphere" size="0.55" pos="0 0 1.15"
                  material="canopy_light_mat" contype="0" conaffinity="0"/>
        </body>

        <!-- Tree 6 — left side -->
        <body name="tree6" pos="-4.5 0.8 0">
            <geom name="trunk6" type="cylinder" size="0.11 0.50" pos="0 0 0.50"
                  material="trunk_mat" contype="1" conaffinity="1"/>
            <geom name="canopy6" type="sphere" size="0.60" pos="0 0 1.30"
                  material="canopy_dark_mat" contype="0" conaffinity="0"/>
            <geom name="canopy6b" type="sphere" size="0.35" pos="0.2 -0.15 1.55"
                  material="canopy_mat" contype="0" conaffinity="0"/>
        </body>

        <!-- New Trees added to the middle for PPO to avoid -->
        <body name="tree7" pos="-1.5 1.5 0">
            <geom name="trunk7" type="cylinder" size="0.10 0.55" pos="0 0 0.55" material="trunk_mat" contype="1" conaffinity="1"/>
            <geom name="canopy7" type="sphere" size="0.55" pos="0 0 1.35" material="canopy_light_mat" contype="0" conaffinity="0"/>
        </body>
        <body name="tree8" pos="1.8 2.2 0">
            <geom name="trunk8" type="cylinder" size="0.08 0.45" pos="0 0 0.45" material="trunk_mat" contype="1" conaffinity="1"/>
            <geom name="canopy8" type="sphere" size="0.45" pos="0 0 1.15" material="canopy_dark_mat" contype="0" conaffinity="0"/>
        </body>
        <body name="tree9" pos="2.0 -1.5 0">
            <geom name="trunk9" type="cylinder" size="0.12 0.60" pos="0 0 0.60" material="trunk_mat" contype="1" conaffinity="1"/>
            <geom name="canopy9" type="sphere" size="0.65" pos="0 0 1.50" material="canopy_mat" contype="0" conaffinity="0"/>
        </body>
        <body name="tree10" pos="-2.2 -2.5 0">
            <geom name="trunk10" type="cylinder" size="0.09 0.50" pos="0 0 0.50" material="trunk_mat" contype="1" conaffinity="1"/>
            <geom name="canopy10" type="sphere" size="0.50" pos="0 0 1.25" material="canopy_light_mat" contype="0" conaffinity="0"/>
        </body>
        <body name="tree11" pos="0 -0.5 0">
            <geom name="trunk11" type="cylinder" size="0.11 0.55" pos="0 0 0.55" material="trunk_mat" contype="1" conaffinity="1"/>
            <geom name="canopy11" type="sphere" size="0.55" pos="0 0 1.35" material="canopy_dark_mat" contype="0" conaffinity="0"/>
        </body>
        <body name="tree12" pos="0.5 1.0 0">
            <geom name="trunk12" type="cylinder" size="0.08 0.40" pos="0 0 0.40" material="trunk_mat" contype="1" conaffinity="1"/>
            <geom name="canopy12" type="sphere" size="0.45" pos="0 0 1.05" material="canopy_mat" contype="0" conaffinity="0"/>
        </body>
        <body name="tree13" pos="-3.0 -0.5 0">
            <geom name="trunk13" type="cylinder" size="0.13 0.65" pos="0 0 0.65" material="trunk_mat" contype="1" conaffinity="1"/>
            <geom name="canopy13" type="sphere" size="0.70" pos="0 0 1.60" material="canopy_light_mat" contype="0" conaffinity="0"/>
        </body>

        <!-- ========================================================== -->
        <!--                      CROP ROWS                             -->
        <!-- ========================================================== -->

        <!-- Trees and Fences are kept as obstacles -->

        <!-- ========================================================== -->
        <!--                    WOODEN FENCE                            -->
        <!-- ========================================================== -->

        <!-- North fence -->
        <geom name="fence_n" type="box" pos="0 5.0 0.12" size="5.2 0.05 0.12" material="fence_mat"/>
        <!-- South fence -->
        <geom name="fence_s" type="box" pos="0 -5.0 0.12" size="5.2 0.05 0.12" material="fence_mat"/>
        <!-- East fence -->
        <geom name="fence_e" type="box" pos="5.0 0 0.12" size="0.05 5.0 0.12" material="fence_mat"/>
        <!-- West fence -->
        <geom name="fence_w" type="box" pos="-5.0 0 0.12" size="0.05 5.0 0.12" material="fence_mat"/>

        <!-- Fence posts (vertical pillars at corners and intervals) -->
        <geom name="fp_ne" type="cylinder" size="0.06 0.18" pos="5.0 5.0 0.18" material="fence_mat"/>
        <geom name="fp_nw" type="cylinder" size="0.06 0.18" pos="-5.0 5.0 0.18" material="fence_mat"/>
        <geom name="fp_se" type="cylinder" size="0.06 0.18" pos="5.0 -5.0 0.18" material="fence_mat"/>
        <geom name="fp_sw" type="cylinder" size="0.06 0.18" pos="-5.0 -5.0 0.18" material="fence_mat"/>
        <geom name="fp_n1" type="cylinder" size="0.04 0.16" pos="2.5 5.0 0.16" material="fence_mat"/>
        <geom name="fp_n2" type="cylinder" size="0.04 0.16" pos="-2.5 5.0 0.16" material="fence_mat"/>
        <geom name="fp_s1" type="cylinder" size="0.04 0.16" pos="2.5 -5.0 0.16" material="fence_mat"/>
        <geom name="fp_s2" type="cylinder" size="0.04 0.16" pos="-2.5 -5.0 0.16" material="fence_mat"/>

        <!-- ========================================================== -->
        <!--              TANK TRACTOR (scaled up ~10×)                 -->
        <!-- ========================================================== -->
        <!--
            Chassis: 1.50 x 0.80 x 0.08 m  (half-sizes below)
            Wheels: radius 0.25, thickness 0.10
            wheelbase: 1.2 m
            track_center_y = 0.40 + 0.10 = 0.50
            body_ground_clearance = 0.30
            body_center_z = 0.30 + 0.04 = 0.34
            wheel_center_rel_z = 0.25 - 0.34 = -0.09
            Spawn height = body_center_z = 0.34
        -->
        <body name="tractor" pos="0 0 0.08">
            <joint type="free"/>

            <!-- Chassis platform -->
            <geom name="chassis" type="box" size="0.12 0.06 0.01"
                  material="chassis_mat" mass="5.0"/>
            <site name="marker" pos="0.12 0 0" size="0.02"/>

            <!-- Ray sites for rangefinders -->
            <!-- Facing Forward, Left, Right, Forward-Left, Forward-Right -->
            <!-- Max range ~ 3m looks good for this small environment -->
            <site name="ray_f" pos="0.12 0 0" size="0.01" type="sphere" rgba="1 0 0 1" euler="0 90 0"/>
            <site name="ray_fl" pos="0.12 0.05 0" size="0.01" type="sphere" rgba="1 0 0 1" euler="0 90 30"/>
            <site name="ray_fr" pos="0.12 -0.05 0" size="0.01" type="sphere" rgba="1 0 0 1" euler="0 90 -30"/>
            <site name="ray_l" pos="0 0.06 0" size="0.01" type="sphere" rgba="1 0 0 1" euler="0 90 90"/>
            <site name="ray_r" pos="0 -0.06 0" size="0.01" type="sphere" rgba="1 0 0 1" euler="0 90 -90"/>

            <!-- ---- Left side ---- -->
            <!-- Front-left drive wheel -->
            <body name="fl_wheel" pos="0.10 0.08 -0.03" euler="90 0 0">
                <joint name="fl-wheel" type="hinge" axis="0 0 -1" damping="0.05" armature="0.1"/>
                <geom name="fl_wheel_geom" type="cylinder" size="0.04 0.015"
                      material="wheel_mat" mass="1.0"/>
            </body>
            <!-- Rear-left drive wheel -->
            <body name="rl_wheel" pos="-0.10 0.08 -0.03" euler="90 0 0">
                <joint name="rl-wheel" type="hinge" axis="0 0 -1" damping="0.05" armature="0.1"/>
                <geom name="rl_wheel_geom" type="cylinder" size="0.04 0.015"
                      material="wheel_mat" mass="1.0"/>
            </body>

            <!-- ---- Right side ---- -->
            <!-- Front-right drive wheel -->
            <body name="fr_wheel" pos="0.10 -0.08 -0.03" euler="90 0 0">
                <joint name="fr-wheel" type="hinge" axis="0 0 -1" damping="0.05" armature="0.1"/>
                <geom name="fr_wheel_geom" type="cylinder" size="0.04 0.015"
                      material="wheel_mat" mass="1.0"/>
            </body>
            <!-- Rear-right drive wheel -->
            <body name="rr_wheel" pos="-0.10 -0.08 -0.03" euler="90 0 0">
                <joint name="rr-wheel" type="hinge" axis="0 0 -1" damping="0.05" armature="0.1"/>
                <geom name="rr_wheel_geom" type="cylinder" size="0.04 0.015"
                      material="wheel_mat" mass="1.0"/>
            </body>
        </body>
    </worldbody>

    <!-- ======================== SENSORS ======================== -->
    <sensor>
        <framepos objtype="site" objname="marker"/>
        <framepos objtype="site" objname="target_site"/>
        <!-- Rangefinders for PPO observation -->
        <rangefinder name="rf_f" site="ray_f" cutoff="3.0"/>
        <rangefinder name="rf_fl" site="ray_fl" cutoff="3.0"/>
        <rangefinder name="rf_fr" site="ray_fr" cutoff="3.0"/>
        <rangefinder name="rf_l" site="ray_l" cutoff="3.0"/>
        <rangefinder name="rf_r" site="ray_r" cutoff="3.0"/>
    </sensor>

    <!-- ======================== ACTUATORS ======================== -->
    <actuator>
        <velocity name="fl-velocity" joint="fl-wheel" kv="5"/>
        <velocity name="rl-velocity" joint="rl-wheel" kv="5"/>
        <velocity name="fr-velocity" joint="fr-wheel" kv="5"/>
        <velocity name="rr-velocity" joint="rr-wheel" kv="5"/>
    </actuator>
</mujoco>
